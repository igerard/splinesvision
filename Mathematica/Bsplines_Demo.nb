Cell["\<\
ipts = {0, 2, 6, 3, 10}
knots = {-2., -1., 0, 2., 6., 9., 16., 17., 18.}
unknowns = {Q[1], Q[2], Q[3], Q[4], Q[5], Q[6]}
ptsEqs = {0.666667 Q[1] + 0.333333 Q[2] == 0, 
 
   0.666667 Q[2] + 0.333333 Q[3] + 0. Q[4] == 2, 
 
   0.428571 Q[3] + 0.571429 Q[4] + 0. Q[5] == 6, 
 
   0.7 Q[4] + 0.3 Q[5] + 0. Q[6] == 3, 
 
   0.125 Q[5] + 0.875 Q[6] == 10}
condsSupp = {0.333333 Q[1] - 0.5 Q[2] + 
 
     0.166667 Q[3] == 0}
sols = {{Q[1] -> -0.5, Q[6] -> 12.5, Q[2] -> 1., 
 
    Q[3] -> 4., Q[4] -> 7.5, Q[5] -> -7.5}}
Le graphe de la solution\
\>", "Print",ExpressionUUID->"e57e6165-0796-4c70-87bf-7588e58b8ea3"],


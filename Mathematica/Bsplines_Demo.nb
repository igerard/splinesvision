Cell[CellGroupData[{

Cell["Interpolation a l'ordre 4", "Subsection",ExpressionUUID->"9c468a20-16c8-49b3-b8b8-4641bae02963"],

Cell[TextData[{
 StyleBox["Dist[a_?NumberQ, b_?NumberQ] := Abs[b - a]\n\nDist[a_?VectorQ, \
b_?VectorQ] := \n  Module[{l = (b-a)}, Sqrt[l . l]]\n  \nunknown[k_,ipts_] := \
\n  Table[Q[i],\n        {i,1,Length[ipts]+k-2}]\n        \n\
interpolsPtsEqs[k_, knots_, ipts_, unknowns_] := \n         \
Table[Sp[k,knots,unknowns] [knots[[i+k-1]]] == \n               ipts[[i]],\n  \
             {i,1,Length[ipts]}]\n\ncondsSuppV0[k_, knots_, unknowns_] := \n  \
{Derivative[1][Sp[k,knots,unknowns]][knots[[k]]] == 0,\n   \
Derivative[1][Sp[k,knots,unknowns]][knots[[",
  FontFamily->"Ohlfs",
  FontSize->10,
  FontWeight->"Plain"],
 StyleBox["-",
  FontSize->10,
  FontWeight->"Plain"],
 StyleBox["k]]] == 0}[[Range[1,k-2]]]\n   \ncondsSuppA0[k_, knots_, \
unknowns_] := \n  {Derivative[2][Sp[k,knots,unknowns]][knots[[k]]] == 0,\n   \
Derivative[2][Sp[k,knots,unknowns]][knots[[-k]]] == 0}",
  FontFamily->"Ohlfs",
  FontSize->10,
  FontWeight->"Plain"],
 StyleBox["[[Range[1,k-2]]]\n   \ncordLengthKnots[k_,ipts_] :=\n  \
Module[{knots = {0},i},\n           For[i = 2, i <= Length[ipts], i++,\n      \
         AppendTo[knots, \n                        knots[[i-1]] +\n           \
             Dist[ipts[[i-1]], ipts[[i]]]]];\n           \
Join[Table[-k+i,{i,1,k-1}],\n                         knots,\n                \
Table[knots[[-1]]+i, {i,1,k-1}]]]\n                \ncentripeteKnots[k_, \
ipts_] :=\n  Module[{knots = {0},i},\n           For[i = 2, i <= \
Length[ipts], i++,\n               AppendTo[knots, \n                        \
knots[[i-1]] +\n                        Sqrt[Dist[ipts[[i-1]], \n             \
                ipts[[i]]]]]];\n           Join[Table[-k+i,{i,1,k-1}],\n      \
                   knots,\n                Table[knots[[-1]]+i, {i,1,k-1}]]]\n\
                     \nInterpolPtsBySpline::usage=\n\
\"InterpolPtsBySpline[ipts, k, parFunc,condSuppFunc,r,g,b,optsGr]\"\n         \
           \nInterpolPtsBySpline[ipts_?VectorQ, \n                    k_, \n  \
                  parFunc_, \n                    condSuppFunc_,\n            \
        r_,g_,b_,\n                    optsGr___] :=\n  Module[{knots, \n     \
     unknowns, \n          ptsEqs, \n          condsSupp, \n          pars, \n\
          sols,\n          fcts,\n          u},\n         Print[\"ipts = \
\",ipts];\n         knots = parFunc[k,ipts] // N;\n         Print[\"knots = \
\", knots];\n         unknowns = unknown[k,ipts];\n         Print[\"unknowns \
= \",unknowns];\n         ptsEqs = interpolsPtsEqs[\n                     \
k,knots, ipts, unknowns];\n         Print[\"ptsEqs = \", ptsEqs];\n         \
condsSupp = condSuppFunc[k,knots,unknowns];\n         Print[\"condsSupp = \
\",condsSupp];\n         sols = Solve[Join[ptsEqs,condsSupp],unknowns];\n     \
    Print[\"sols = \",sols];\n         fcts = Sp[k,knots,unknowns][u] /. \
sols[[1]];\n         pars = knots[[Range[k,Length[knots]-k+1]]];\n         \
(**Print[\"pars = \",pars];**)\n         (**Print[\"fcts = \",fcts];**)\n     \
    Print[\"Le graphe de la solution\"];\n         Plot[fcts,\n              \
{u,knots[[k]], knots[[-k]]},\n              Prolog -> {PointSize[0.02],\n     \
                    Map[Point,Transpose[{pars,ipts}]],\n                      \
   RGBColor[r,g,b]},\n              optsGr];\n         Sp[k,knots,unknowns /. \
sols[[1]]]]\nInterpolPtsBySpline[iptsND_?MatrixQ, \n                    k_, \n\
                    parFunc_, \n                    condSuppFunc_,\n          \
          r_,g_,b_,\n                    debug_,\n                    \
optsGr___] :=\n  Module[{ipts = Transpose[iptsND],\n          knots, \n       \
   unknowns, \n          ptsEqs, \n          condsSupp, \n          sols,\n   \
       fcts,\n          u},\n         If[debug, Print[\"ipts = \",ipts]];\n   \
      knots = parFunc[k,iptsND] // N;\n         If[debug,Print[\"knots = \", \
knots]];\n         unknowns = unknown[k,iptsND];\n         \
If[debug,Print[\"unknowns = \",unknowns]];\n         ptsEqs = \n           \
Map[interpolsPtsEqs[\n                 k,knots, #, unknowns]&, ipts];\n       \
  If[debug,Print[\"ptsEqs = \", ptsEqs]];\n         condsSupp = \
condSuppFunc[k,knots,unknowns];\n         If[debug,Print[\"condsSupp = \
\",condsSupp]];\n         sols = \n           \
Map[Solve[Join[#,condsSupp],unknowns]&,ptsEqs];\n         \
If[debug,Print[\"sols = \",sols]];\n         fcts = \
Map[Sp[k,knots,unknowns][u] /. #[[1]]&,sols];\n         If[Length[ipts] == 2,\
\n            ParametricPlot[fcts,{u,knots[[k]], knots[[-k]]},\n              \
             Prolog -> {RGBColor[r,g,b]},\n                           Epilog \
-> {GrayLevel[0],\n                                      PointSize[0.02], \n  \
                                    Map[Point,iptsND]},\n                     \
      optsGr],\n            ParametricPlot3D[fcts,{u,knots[[k]], \
knots[[-k]]},\n                           Prolog -> {RGBColor[r,g,b]},\n      \
                     Epilog -> {GrayLevel[0],\n                               \
       PointSize[0.02], \n                                      \
Map[Point,iptsND]},\n                             optsGr]];\n         \
Sp[k,knots,\n            Transpose[Map[unknowns /. #[[1]]&,sols]]\n           \
]\n       ]",
  FontFamily->"Ohlfs",
  FontSize->10,
  FontWeight->"Plain"]
}], "Input",ExpressionUUID->"98e56ff6-69db-4d19-a782-e471d3cf045c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Test avec ordre 2", "Subsection",ExpressionUUID->"1e7023ae-1af0-453e-b436-b9d18d76b641"],

Cell[CellGroupData[{

Cell["\<\
InterpolPtsBySpline[{0,2,6,3,10},
                     2,
                     cordLengthKnots,
                     condsSuppV0,
                     1.0,0,0]\
\>", "Input",ExpressionUUID->"28b30809-709c-4be8-9a9b-292196ef3467"],

Cell["\<\
ipts = {0, 2, 6, 3, 10}
knots = {-1., 0, 2., 6., 9., 16., 17.}
unknowns = {Q[1], Q[2], Q[3], Q[4], Q[5]}
ptsEqs = {1. Q[1] == 0, 1. Q[2] + 0. Q[3] == 2, 
 
   1. Q[3] + 0. Q[4] == 6, 1. Q[4] + 0. Q[5] == 3, 
 
   1. Q[5] == 10}
condsSupp = {}
sols = {{Q[1] -> 0., Q[2] -> 2., Q[3] -> 6., 
 
    Q[4] -> 3., Q[5] -> 10.}}
Le graphe de la solution\
\>", "Print",ExpressionUUID->"710d424e-8680-4092-af42-4a0623322971"],


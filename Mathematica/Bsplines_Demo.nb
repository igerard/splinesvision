Cell[TextData[{
 StyleBox["k = 4;\nknots = {",
  FontFamily->"Ohlfs",
  FontSize->10,
  FontWeight->"Plain"],
 StyleBox["-1,0,0,0,2,3,3,3,4};\nCSp = Sp[k,\n         knots,\n         \
{{0,0},{2,1},{2,3},{6,3},{8,5}}];\na = knots[[k]];\nb = knots[[-k]];\n\
polpoints = Table[CSp[u],\n                  {u,a,b,0.1}];\nsamplePoints = \
Table[CSp[u],\n                  {u,a,b,0.25}];\nsampleTG = \
Table[Evaluate[CSp'][u],\n                  {u,a,b,0.25}];\nsbt = \
Map[Line[{#[[1]],#[[1]]+#[[2]]}]&,\n          \
Transpose[{samplePoints,sampleTG}]];\nsampleTA = Table[Evaluate[CSp''][u],\n  \
                {u,a,b,0.25}];\nsba = Map[Line[{#[[1]],#[[1]]+#[[2]]}]&,\n    \
      Transpose[{samplePoints,sampleTA}]];\nSpWithTG = \n  \
Show[Graphics[{Thickness[0.001],\n                 Line[polpoints],\n         \
        PointSize[0.008],\n                 Map[Point,polpoints],\n           \
      RGBColor[1,0,0],\n                 sbt,\n                 \
RGBColor[0,0,1],\n                 sba}],\n       Axes -> True,\n       \
PlotRange -> Automatic]",
  FontSize->10,
  FontWeight->"Plain"]
}], "Input",
 CellChangeTimes->{{3.988826511307342*^9, 3.9888265921816883`*^9}, {
   3.988826632926466*^9, 3.988826640120344*^9}, {3.988826671179391*^9, 

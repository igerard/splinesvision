Cell[CellGroupData[{

Cell["Fonction Spline", "Subtitle",ExpressionUUID->"bc6fd421-704e-42cf-8597-770bca8ed6f5"],

Cell[TextData[{
 "Exprim\[EAcute]es sous forme de combinaison lin\[EAcute]aire des fonctions \
de bases fourni une fonction polynomiale par morceaux d\[EAcute]finie sur \
intervalle [",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "d"], ",", " ", 
    SubscriptBox["U", 
     RowBox[{
      RowBox[{"Length", "[", "K", "]"}], "-", "d", "-", "1"}]]}], 
   TraditionalForm]],ExpressionUUID->"854c79bd-1098-46c9-b649-519d89bbba7f"],
 "[ :"
}], "Text",ExpressionUUID->"0f418ab8-eee7-4eb9-ad65-b3fd0e250b70"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["Bs", 
    RowBox[{"p_", ",", "U_", ",", "P_"}]], "[", "u_", "]"}], " ", ":=", " ", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"i", "=", "0"}], 
    RowBox[{
     RowBox[{"Length", "[", "U", "]"}], "-", "p", "-", "2"}]], 
   RowBox[{
    RowBox[{
     SubscriptBox["N", 
      RowBox[{"i", ",", "p", ",", "U"}]], "[", "u", "]"}], 
    SubscriptBox["P", "i"]}]}]}]], "Input",
 CellLabel->
  "In[113]:=",ExpressionUUID->"70d0f4fc-314c-4cdc-9628-1c616f3130ff"],


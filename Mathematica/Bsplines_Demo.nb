Cell["\<\
TriedreSurf[s_Sp,u_,v_] :=
  Block[{spU = Derivative[1,0][s],
          spV = Derivative[0,1][s],
          p = s[u,v],
          vU = spU[u,v],
          vV = spV[u,v],
          n = vU ~Cross~ vV},
      Print[p];
      Print[vU];
      Print[vV];
      Print[n];
      Graphics3D[{Line[{p,p+vU}],
                  Line[{p,p+vV}],
                  Line[{p,p+n}]}]]
            
TriedreSurf[s_Sp,spU_,spV_,{u_,v_}] :=
  Block[{p = s[u,v],
          vU = spU[u,v],
          vV = spV[u,v],
          n = vU ~Cross~ vV},
      {AbsoluteThickness[3],
       RGBColor[1,0,0],
       Line[{p,p+vU}],
       RGBColor[0,1,0],
       Line[{p,p+vV}],
       RGBColor[0,0,1],
       Line[{p,p+n}]}]
            
TriedreSurf[s_Sp,pars:{{_,_}..}] :=
  Block[{spU = Derivative[1,0][s],
          spV = Derivative[0,1][s]},
      Map[TriedreSurf[s,spU,spV,#]&,pars]]
            \
\>", "Input",
 CellLabel->
  "In[437]:=",ExpressionUUID->"3b4987d8-ff49-4782-b0ce-1d595ce7877b"],


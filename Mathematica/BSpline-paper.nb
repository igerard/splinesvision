Cell[CellGroupData[{

Cell["Surface param\[EAcute]trique", "Subtitle",ExpressionUUID->"5022bf48-e147-4792-94a2-c2e709516cf3"],

Cell["\<\
Une surface param\[EAcute]trique B-Spline est fonction de deux \
param\[EGrave]tres u et v, produit de chacune des 'directions' : \
\>", "Text",ExpressionUUID->"c7908c46-ed84-455c-9e52-75f70bb32d0c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["BsS", 
    RowBox[{"du_", ",", "U_", ",", "dv_", ",", "V_", ",", "P_"}]], "[", 
   RowBox[{"u_", ",", "v_"}], "]"}], ":=", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"i", "=", "0"}], 
    RowBox[{
     RowBox[{"Length", "[", "U", "]"}], "-", "du", "-", "2"}]], 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"j", "=", "0"}], 
     RowBox[{
      RowBox[{"Length", "[", "V", "]"}], "-", "dv", "-", "2"}]], 
    RowBox[{
     RowBox[{
      SubscriptBox["N", 
       RowBox[{"i", ",", "du", ",", "U"}]], "[", "u", "]"}], 
     RowBox[{
      SubscriptBox["N", 
       RowBox[{"j", ",", "dv", ",", "V"}]], "[", "v", "]"}], 
     SubscriptBox["P", 
      RowBox[{"i", ",", "j"}]]}]}]}]}]], "Input",
 CellLabel->"In[24]:=",ExpressionUUID->"00e27646-de98-457a-8376-10afea95d75c"],

Cell["\<\
Les deux directions sont ind\[EAcute]pendant, elle peuvent avoir un degr\
\[EAcute]s et un vecteur n\[OE]ud diff\[EAcute]rent...\
\>", "Text",ExpressionUUID->"cbb00059-30bc-4624-88f8-f9f23caac7e6"],

Cell[CellGroupData[{

Cell["Exemple (la figure de la premi\[EGrave]re page)", "Subsection",ExpressionUUID->"1327cb27-a216-4fef-81e9-a2e508746c4f"],


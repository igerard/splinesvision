Cell["Courbe param\[EAcute]trique", "Subtitle",ExpressionUUID->"4a915b5b-cd13-41af-a99d-960dbc097adc"],

Cell["\<\
Les splines deviennent vraiment int\[EAcute]ressante lorsque elles sont \
utilis\[EAcute]es pour d\[EAcute]crire des courbes ou surface \
param\[EAcute]triques, c'est \[AGrave] dire une ensemble de points du plan, \
ou de l'espace, dont chaque composante est une fonction B-Spline exprim\
\[EAcute] dans la m\[EHat]me base de fonctions splines.\
\>", "Text",ExpressionUUID->"e0b5f0e3-c143-439c-a944-c26b5414fee8"],

Cell[TextData[{
 "Pour une courbe param\[EAcute]trique B-Spline dans l'espace ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["R", "n"], TraditionalForm]],ExpressionUUID->
  "e8ee90c1-568b-47da-9c2a-018257ea02b4"],
 ", dont les coefficients sont des points de l'espace ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["R", "n"], TraditionalForm]],ExpressionUUID->
  "ecba6ed2-7d52-41c6-b4e1-a5549ae855b0"],
 "sous la forme : ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "0"], ",", " ", 
       SubscriptBox["y", "0"], ",", " ", 
       SubscriptBox["z", "0"]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", " ", 
       SubscriptBox["y", "1"], ",", " ", 
       SubscriptBox["z", "1"]}], "}"}], ",", " ", "...", ",", " ", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", 
        RowBox[{
         RowBox[{"Length", "[", "K", "]"}], "-", "d", "-", "2"}]], ",", " ", 
       SubscriptBox["y", 
        RowBox[{
         RowBox[{"Length", "[", "K", "]"}], "-", "d", "-", "2"}]], ",", " ", 
       SubscriptBox["z", 
        RowBox[{
         RowBox[{"Length", "[", "K", "]"}], "-", "d", "-", "2"}]]}], "}"}]}], 
    "}"}], TraditionalForm]],ExpressionUUID->
  "c6944f82-d625-4e17-8806-98e21f54fdff"]
}], "Text",ExpressionUUID->"54b39234-7d29-4e83-896e-f599c8f25bc6"],

Cell["\<\
Nous avons simplement la g\[EAcute]n\[EAcute]ralisation de l'expression des \
fonctions r\[EAcute]elles :\
\>", "Text",ExpressionUUID->"b00d549e-3288-4441-8726-f029d931f97b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["BsP", 
    RowBox[{"d_", ",", "U_", ",", "P_"}]], "[", "u_", "]"}], ":=", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"i", "=", "0"}], 
    RowBox[{
     RowBox[{"Length", "[", "U", "]"}], "-", "d", "-", "2"}]], 
   RowBox[{
    RowBox[{
     SubscriptBox["N", 
      RowBox[{"i", ",", "d", ",", "U"}]], "[", "u", "]"}], " ", 
    SubscriptBox["P", "i"]}]}]}]], "Input",
 CellLabel->
  "In[120]:=",ExpressionUUID->"69cd44b0-9628-4516-9c10-5c14b4368b65"],

Cell[CellGroupData[{

Cell["Exemples", "Subsection",ExpressionUUID->"bf6d0af6-0a67-4d8a-91b1-5b2db5101f58"],

Cell[CellGroupData[{

Cell["Une courbe dans le plan", "Subsubsection",ExpressionUUID->"039a19c0-00a9-4c00-85c8-b49965ea33c8"],

Cell["\<\
Les coordonn\[EAcute]es dans le plan, que l'on nomme 'polygone descripteur' :\
\
\>", "Text",ExpressionUUID->"0c19d0cc-5d47-4dd8-b48e-a68880ef4519"],

Cell[BoxData[
 RowBox[{
  RowBox[{"P2D", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0.2", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3.5", ",", "20"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"4", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"6", ",", "0"}], "}"}]}], "}"}]}], ";"}]], "Input",
 CellLabel->
  "In[121]:=",ExpressionUUID->"4becfef7-1b96-42af-9cb8-9d78940c61bb"],

Cell["Un trac\[EAcute] silencieux", "Text",ExpressionUUID->"c71d0da4-4b64-4b14-993b-87548bce1c53"],

Cell[BoxData[
 RowBox[{
  RowBox[{"polyGR", " ", "=", " ", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["BsP", 
       RowBox[{"d", ",", "K", ",", "P2D"}]], "[", "u", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"u", ",", " ", "0", ",", " ", "3"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[122]:=",ExpressionUUID->"9ccb985d-6b5f-4ba2-8748-149722253878"],

Cell["La combinaison avec le polygone descripteur :", "Text",ExpressionUUID->"54e86bdf-ed2d-4e64-b410-5443d2028426"],


Cell[CellGroupData[{

Cell["Exemple", "Subsection",ExpressionUUID->"2bed4307-137b-4728-aefe-ca42933a4cab"],

Cell["Pour l'ensemble des fonctions splines de degr\[EAcute] :", "Text",ExpressionUUID->"cf2fba67-4ef7-4ac6-85ca-1cddc515806c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"d", " ", "=", " ", "3"}], ";"}]], "Input",
 CellLabel->
  "In[110]:=",ExpressionUUID->"14c24a23-6b88-48c8-b16a-44081ba52255"],

Cell["\<\
ayant pour support la s\[EAcute]rie croissante de r\[EAcute]els, que l'on \
appelle vecteur n\[OE]ud' :\
\>", "Text",ExpressionUUID->"0fed1122-a45e-4991-b679-8664083d82e3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"K", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
    "0", ",", "0", ",", "0", ",", "0", ",", "1", ",", "2", ",", "3", ",", "3",
      ",", "3", ",", "4"}], "}"}]}], ";"}]], "Input",
 CellLabel->
  "In[111]:=",ExpressionUUID->"a291604f-9afa-4308-aba0-44e2b18f847d"],

Cell["\<\
Le 'vecteur n\[OE]ud' joue un r\[OHat]le d'importance car il d\[EAcute]fini \
la longueur param\[EAcute]trique des arc polynomiaux de la courbe \[AGrave] d\
\[EAcute]finir. \
\>", "Text",ExpressionUUID->"bacac0e3-7854-4523-ba19-6c7b6d9be377"],

Cell[TextData[{
 "Ici j'ai utilis\[EAcute] une astuce: {....,3,3,3,4}, qui permet \
d'\[EAcute]viter une discontinuit\[EAcute] en ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", "3"}], TraditionalForm]],ExpressionUUID->
  "cfa240ed-a67e-4f30-9b80-c062d5ccac06"],
 ", bien utile lors des \[EAcute]valuations num\[EAcute]riques."
}], "Text",ExpressionUUID->"9f104f62-33e4-47b7-a0ff-37e47bce9695"],

Cell[TextData[{
 "Les fonctions de base sont d\[EAcute]finies sur les supports successifs ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "i"], 
    SubscriptBox["U", 
     RowBox[{"i", "+", "d", "+", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "b1369a8e-1f3e-4ab6-8a1b-fc88099513b2"],
 "avec i\[Element]{0,5}"
}], "Text",ExpressionUUID->"6c586381-12df-4fad-84b6-f441a6d2970a"],

Cell["\<\
Le trac\[EAcute] ne s'int\[EAcute]resse qu'\[AGrave] l'intervalle[0,3[car \
c'est l'intervalle pertinent pour les fonctions qui seront d\[EAcute]finies \
gr\[AHat]ce \[AGrave] cette base.\
\>", "Text",ExpressionUUID->"2d731c34-6804-4f4e-822b-5853583963ab"],

